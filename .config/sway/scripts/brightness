case $1 in
    +)
        emoji="🔆"
        brightnessctl set +2%;;
    -)
        emoji="🔅"
        brightnessctl set 2%-;;
esac

MAX=${MAX:-$(brightnessctl m)}
VAL=$(brightnessctl g)

notify-send -a "brightness" -t 1500 -h string:x-dunst-stack-tag:brightness-volume -h int:value:"$(($VAL * 100 / $MAX))" "Brightness $emoji"
