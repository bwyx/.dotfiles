case $1 in
    +)
        emoji="🔊"
        wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%+;;
    -)
        emoji="🔈"
        wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%-;;
esac

VOL=$(wpctl get-volume @DEFAULT_AUDIO_SINK@)
VAL=${VOL:10}

notify-send -a "brightness" -t 1500 -h string:x-dunst-stack-tag:brightness-volume -h int:value:"$VAL" "Volume $emoji"
